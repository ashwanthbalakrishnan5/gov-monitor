# Service worker must never be cached — browser needs to fetch fresh on every check
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# HTML shell must revalidate so the browser picks up new asset hashes
/index.html
  Cache-Control: no-cache, must-revalidate

# Root path serves index.html
/
  Cache-Control: no-cache, must-revalidate

# Hashed build assets are immutable — cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable
